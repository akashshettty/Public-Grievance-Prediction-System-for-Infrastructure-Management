"""
Example .env file for environment configuration
Copy this file to .env and update values
"""

# Flask Configuration
FLASK_ENV=development
FLASK_APP=wsgi.py
FLASK_DEBUG=True
FLASK_PORT=5000

# Database Configuration (For Future Use)
DATABASE_URL=sqlite:///urbanpulse.db
DATABASE_POOL_SIZE=10
DATABASE_POOL_TIMEOUT=30

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# Data Paths
DATA_DIR=./data
PROCESSED_DATA_DIR=./data/processed

# Cache Configuration
CACHE_ENABLED=True
CACHE_TIMEOUT=300

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# API Configuration
API_TITLE=UrbanPulse AI API
API_VERSION=2.0.0
API_DESCRIPTION=Smart city infrastructure management and complaint analytics

# AI Model Configuration (For Future Use)
NLP_MODEL_PATH=./models/nlp
FORECASTING_MODEL_PATH=./models/forecasting
FRAUD_DETECTION_MODEL_PATH=./models/fraud_detection

# External API Keys (For Future Use)
WEATHER_API_KEY=
TRAFFIC_API_KEY=
SOCIAL_MEDIA_API_KEY=

# Monitoring & Logging
SENTRY_DSN=
LOGS_DIR=./logs

# Development Settings
DEBUG_ENDPOINTS=True
MOCK_DATA_ENABLED=True

# Production Settings (Uncomment for production)
# FLASK_ENV=production
# FLASK_DEBUG=False
# DEBUG_ENDPOINTS=False
# CACHE_ENABLED=True
# LOG_LEVEL=WARNING
